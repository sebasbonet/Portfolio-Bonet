rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Portfolio rules
    match /portfolios/{portfolioId} {
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'name'])
        && request.resource.data.name is string;
      
      allow read, update, delete: if isOwner(resource.data.userId);

      // Holdings subcollection
      match /holdings/{holdingId} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/portfolios/$(portfolioId)).data.userId);
      }

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/portfolios/$(portfolioId)).data.userId);
      }
    }

    // User-specific dividends
    match /users/{userId}/dividends/{dividendId} {
      allow read, write: if isOwner(userId);
    }

    // Global news cache - System managed (simulated here as restricted write)
    match /news/{newsId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via admin or system (server side using service account)
    }
  }
}
